<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="009-create-event-publication-tables" author="franklin">
        <createTable tableName="event_publication">
            <column name="id" type="uuid">
                <constraints primaryKey="true" primaryKeyName="pk_event_publication" nullable="false"/>
            </column>
            <column name="publication_date" type="timestamp">
                <constraints nullable="false"/>
            </column>
            <column name="listener_id" type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="serialized_event" type="text">
                <constraints nullable="false"/>
            </column>
            <column name="event_type" type="varchar(512)">
                <constraints nullable="false"/>
            </column>
            <column name="completion_date" type="timestamp"/>
            <column name="last_resubmission_date" type="timestamp"/>
            <column name="completion_attempts" type="int" defaultValueNumeric="0">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="varchar(30)">
                <constraints nullable="false"/>
            </column>
        </createTable>

        <createIndex indexName="idx_event_publication_status" tableName="event_publication">
            <column name="status"/>
        </createIndex>
    </changeSet>
</databaseChangeLog>
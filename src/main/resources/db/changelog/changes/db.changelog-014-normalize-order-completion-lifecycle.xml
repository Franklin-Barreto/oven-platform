<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="014-normalize-order-completion-lifecycle" author="franklin">
        <renameColumn
                tableName="orders"
                oldColumnName="delivered_at"
                newColumnName="completed_at"
                columnDataType="timestamp"/>

        <update tableName="orders">
            <column name="status" value="COMPLETED"/>
            <where>status = 'DELIVERED'</where>
        </update>
    </changeSet>
</databaseChangeLog>

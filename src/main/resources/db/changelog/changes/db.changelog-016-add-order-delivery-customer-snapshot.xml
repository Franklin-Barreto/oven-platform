<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
        http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="016-add-order-delivery-customer-snapshot" author="franklin">
        <addColumn tableName="orders">
            <column name="customer_id" type="uuid"/>
            <column name="customer_name" type="varchar(80)"/>
            <column name="customer_phone" type="varchar(30)"/>
            <column name="delivery_address_id" type="uuid"/>
            <column name="delivery_address_label" type="varchar(40)"/>
            <column name="delivery_address_line_1" type="varchar(120)"/>
            <column name="delivery_number" type="varchar(20)"/>
            <column name="delivery_complement" type="varchar(120)"/>
            <column name="delivery_neighborhood" type="varchar(80)"/>
            <column name="delivery_city" type="varchar(80)"/>
            <column name="delivery_state" type="varchar(40)"/>
            <column name="delivery_postal_code" type="varchar(20)"/>
            <column name="delivery_reference" type="varchar(160)"/>
        </addColumn>
    </changeSet>
</databaseChangeLog>
